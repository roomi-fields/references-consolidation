# Exemple de configuration pour pipeline/cascade_sources/
# Copie ce fichier en `.env` à la racine du projet et remplis les clés.
# Le `.env` est gitignored, jamais commit.

# Semantic Scholar API key (recommandé pour éviter rate-limiting 429)
# Demande gratuite : https://www.semanticscholar.org/product/api#api-key-form
PAPER_SEARCH_MCP_SEMANTIC_SCHOLAR_API_KEY=

# Unpaywall email (déjà utilisé par cascade native via lib/oa_finder.py)
PAPER_SEARCH_MCP_UNPAYWALL_EMAIL=
